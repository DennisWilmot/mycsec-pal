{
  "name": "mycsecpal-nextjs",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "$postcss"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:docs": "node scripts/check-doc-headers.mjs",
    "test:smoke": "node scripts/smoke-app.mjs",
    "perf:http": "node scripts/http-benchmark.mjs",
    "validate:precommit": "npm run lint && npm run typecheck && npm test && npm run test:docs",
    "validate:full": "node scripts/validate-full.mjs",
    "hooks:install": "bin/install-agent-hooks",
    "agent:session": "node scripts/agent-session.mjs",
    "agent:review": "node scripts/agent-review.mjs",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:security:check": "node --env-file=.env --import tsx scripts/verify-database-role.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --env-file=.env --import tsx drizzle/seed.ts",
    "db:seed:validate": "node --import tsx -e \"import('./drizzle/seed-data/mathematics.js').then((seed) => { const validate = seed.validateMathematicsSeed ?? seed.default?.validateMathematicsSeed; if (typeof validate !== 'function') throw new Error('Mathematics seed validator export is unavailable.'); const result = validate(); console.log(JSON.stringify(result, null, 2)); if (!result.valid) process.exit(1); })\"",
    "math:review:validate": "node --import tsx scripts/validate-mathematics-review.mjs",
    "pool:progress:update": "node scripts/update-question-pool-progress.mjs",
    "pool:release:verify": "node --env-file=.env --import tsx scripts/verify-question-pool-release.mjs",
    "english:release:validate": "node --import tsx scripts/validate-english-release.mjs",
    "db:seed:english:review": "node --env-file=.env --import tsx drizzle/seed-english.ts",
    "test-user:create": "node --env-file=.env scripts/create-test-user.mjs",
    "test-user:password:reset": "node --env-file=.env scripts/reset-test-user-password.mjs",
    "test:authz": "node scripts/test-cross-user-authorization.mjs",
    "load:test": "k6 run load/k6-concurrent-exams.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.12.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "postcss": "^8.5.19",
    "postgres": "^3.4.9",
    "posthog-js": "^1.404.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^6.1.0",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "19.2.17",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.20",
    "tsx": "^4.23.0",
    "typescript": "5.8.2"
  }
}
